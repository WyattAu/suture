#!/usr/bin/env bash
# suture pre-commit hook
# Runs fmt, clippy, and the full test suite before allowing a commit.
# Install: cp scripts/pre-commit .git/hooks/pre-commit
#
# To bypass (emergency only): SUTURE_SKIP_CHECKS=1 git commit ...

set -euo pipefail

if [ "${SUTURE_SKIP_CHECKS:-0}" = "1" ]; then
    echo "SUTURE_SKIP_CHECKS=1 -- skipping pre-commit checks"
    exit 0
fi

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

EXCLUDE="--exclude suture-fuzz --exclude suture-py --exclude suture-node --exclude suture-e2e --exclude suture-bench --exclude suture-vfs --exclude suture-lsp --exclude suture-daemon"

echo ""
echo "=== suture pre-commit quality gates ==="
echo ""

FAIL=0

# --- 1. cargo fmt ---
echo -n "[1/3] cargo fmt --check ... "
if cargo fmt --all -- --check 2>&1; then
    echo -e "${GREEN}PASS${NC}"
else
    echo -e "${RED}FAIL${NC}"
    FAIL=1
fi

# --- 2. cargo clippy (includes type-check, no separate cargo check needed) ---
echo -n "[2/3] cargo clippy --workspace ${EXCLUDE} -- -D warnings ... "
if cargo clippy --workspace ${EXCLUDE} -- -D warnings 2>&1; then
    echo -e "${GREEN}PASS${NC}"
else
    echo -e "${RED}FAIL${NC}"
    FAIL=1
fi

# --- 3. cargo test (full workspace, serial for CWD-dependent tests) ---
echo "[3/3] cargo test --workspace ${EXCLUDE} -- --test-threads=1 ..."
if cargo test --workspace ${EXCLUDE} -- --test-threads=1 2>&1; then
    echo -e "${GREEN}PASS${NC}"
else
    echo -e "${RED}FAIL${NC}"
    FAIL=1
fi

echo ""
if [ "$FAIL" -ne 0 ]; then
    echo -e "${RED}Pre-commit checks FAILED. Commit aborted.${NC}"
    echo -e "${YELLOW}Fix the issues above and try again.${NC}"
    echo -e "${YELLOW}Emergency bypass: SUTURE_SKIP_CHECKS=1 git commit ...${NC}"
    exit 1
fi

echo -e "${GREEN}All quality gates passed. Proceeding with commit.${NC}"
echo ""
