#!/usr/bin/env bash
# suture pre-push hook
# Runs fmt, clippy, and test suite before allowing a push to remote.
# Install: cp scripts/pre-push .git/hooks/pre-push
#
# To bypass (emergency only): SUTURE_SKIP_PUSH_CHECKS=1 git push ...

set -euo pipefail

if [ "${SUTURE_SKIP_PUSH_CHECKS:-0}" = "1" ]; then
    echo "SUTURE_SKIP_PUSH_CHECKS=1 -- skipping pre-push checks"
    exit 0
fi

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

EXCLUDE="--exclude suture-fuzz --exclude suture-py --exclude suture-node --exclude suture-e2e --exclude suture-bench --exclude suture-vfs --exclude suture-lsp --exclude suture-daemon"

echo ""
echo "=== suture pre-push quality gates ==="
echo ""

FAIL=0

# --- 1. cargo fmt ---
echo -n "[1/3] cargo fmt --check ... "
if cargo fmt --all -- --check 2>&1; then
    echo -e "${GREEN}PASS${NC}"
else
    echo -e "${RED}FAIL${NC}"
    FAIL=1
fi

# --- 2. cargo clippy (includes type-check, no separate cargo check needed) ---
echo -n "[2/3] cargo clippy --workspace ${EXCLUDE} -- -D warnings ... "
if cargo clippy --workspace ${EXCLUDE} -- -D warnings 2>&1; then
    echo -e "${GREEN}PASS${NC}"
else
    echo -e "${RED}FAIL${NC}"
    FAIL=1
fi

# --- 3. cargo test (serial for CWD-dependent CLI tests) ---
echo "[3/3] cargo test --workspace ${EXCLUDE} -- --test-threads=1 ..."
if cargo test --workspace ${EXCLUDE} -- --test-threads=1 2>&1; then
    echo -e "${GREEN}PASS${NC}"
else
    echo -e "${RED}FAIL${NC}"
    FAIL=1
fi

echo ""
if [ "$FAIL" -ne 0 ]; then
    echo -e "${RED}Pre-push checks FAILED. Push aborted.${NC}"
    echo -e "${YELLOW}Fix the issues above and try again.${NC}"
    echo -e "${YELLOW}Emergency bypass: SUTURE_SKIP_PUSH_CHECKS=1 git push ...${NC}"
    exit 1
fi

echo -e "${GREEN}All quality gates passed. Proceeding with push.${NC}"
echo ""
