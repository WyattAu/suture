{
  "$schema": "https://raw.githubusercontent.com/nickel-org/nickel.rs/master/nickel/schema.json",
  "productName": "Suture",
  "version": "1.2.0",
  "identifier": "com.suture.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../desktop-app/ui"
  },
  "app": {
    "title": "Suture USVCS",
    "windows": [
      {
        "title": "Suture — Universal Semantic Version Control",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
