#!/bin/bash
# Suture Git Merge Driver
#
# Lets Git use Suture's semantic merge for conflict resolution on structured
# files (JSON, YAML, TOML, CSV, XML, Markdown). When a merge conflict occurs
# on a configured file type, Git invokes this script with three file paths:
#
#   $1 = %O  (base/ancestor version)
#   $2 = %A  (ours version — Git reads this back as the merge result)
#   $3 = %B  (theirs version)
#
# If the merge succeeds, the merged content is written to $2 and the script
# exits 0. If it fails, Git falls back to its default line-based merge.
#
# --- SETUP ---
#
# 1. Register the driver (run once per repo or globally with --global):
#
#      git config merge.suture.name "Suture semantic merge"
#      git config merge.suture.driver "/path/to/suture-merge-driver %O %A %B"
#
# 2. Tell Git which file types to route through Suture (add to .gitattributes):
#
#      echo "*.json merge=suture"  >> .gitattributes
#      echo "*.yaml merge=suture"  >> .gitattributes
#      echo "*.yml  merge=suture"  >> .gitattributes
#      echo "*.toml merge=suture"  >> .gitattributes
#      echo "*.csv  merge=suture"  >> .gitattributes
#      echo "*.xml  merge=suture"  >> .gitattributes
#      echo "*.md   merge=suture"  >> .gitattributes
#
# 3. Commit .gitattributes and merge normally:
#
#      git add .gitattributes
#      git commit -m "Configure suture merge driver"
#
# See docs/git_merge_driver.md for full documentation.

set -euo pipefail

BASE="$1"
OURS="$2"
THEIRS="$3"

# --- Locate the suture binary ---
# Priority: PATH > SUTURE_PATH env var
if command -v suture &>/dev/null; then
    SUTURE="suture"
elif [ -n "${SUTURE_PATH:-}" ]; then
    SUTURE="$SUTURE_PATH"
else
    echo "suture: command not found. Install with: cargo install suture-cli" >&2
    exit 1
fi

# --- Detect driver from file extension ---
EXT="${OURS##*.}"
case "$EXT" in
    json|yaml|yml|toml|csv|xml|md)
        DRIVER="--driver $EXT"
        ;;
    *)
        # Unknown extension — fall back to Git's default line-based merge
        cp "$THEIRS" "$OURS"
        exit 0
        ;;
esac

# --- Run semantic merge ---
if "$SUTURE" merge-file $DRIVER "$BASE" "$OURS" "$THEIRS" -o "$OURS" 2>/dev/null; then
    # Clean merge — result written to $2 (ours), mark as resolved
    exit 0
else
    # Semantic merge reported a conflict — try line-based merge as fallback
    if "$SUTURE" merge-file "$BASE" "$OURS" "$THEIRS" -o "$OURS" 2>/dev/null; then
        exit 0
    fi
    # Neither semantic nor line-based merge succeeded.
    # Exit non-zero so Git falls back to its default conflict behavior.
    echo "suture: merge conflict on $OURS" >&2
    exit 1
fi
