#!/bin/bash
# Suture Git Merge Driver
#
# Lets Git use Suture's semantic merge for conflict resolution on structured
# files. When a merge conflict occurs on a configured file type, Git invokes
# this script with three file paths:
#
#   $1 = %O  (base/ancestor version)
#   $2 = %A  (ours version — Git reads this back as the merge result)
#   $3 = %B  (theirs version)
#   $4 = %P  (original file path — used for extension detection)
#
# If the merge succeeds, the merged content is written to $2 and the script
# exits 0. If it fails, Git falls back to its default line-based merge.
#
# --- QUICK SETUP ---
#
#   suture git driver install
#
# Or manually:
#
#   git config merge.suture.name "Suture semantic merge"
#   git config merge.suture.driver "/path/to/suture-merge-driver %O %A %B %P"
#   echo "*.json merge=suture" >> .gitattributes
#
# See docs/git_merge_driver.md for full documentation.

set -euo pipefail

BASE="$1"
OURS="$2"
THEIRS="$3"

# --- Locate the suture binary ---
# Priority: PATH > SUTURE_PATH env var
if command -v suture &>/dev/null; then
    SUTURE="suture"
elif [ -n "${SUTURE_PATH:-}" ]; then
    SUTURE="$SUTURE_PATH"
else
    echo "suture: command not found. Install with: cargo install suture-cli" >&2
    exit 1
fi

# --- Run semantic merge with auto driver detection ---
# --driver auto detects the driver from the original file path (%P).
# For binary formats (DOCX, XLSX, PPTX), Suture reads the ZIP, merges at
# the structural level, and writes a new ZIP.
if "$SUTURE" merge-file --driver auto "$BASE" "$OURS" "$THEIRS" -o "$OURS" 2>/dev/null; then
    # Clean merge — result written to $2 (ours), mark as resolved
    exit 0
else
    # Semantic merge reported a conflict — try line-based merge as fallback
    if "$SUTURE" merge-file "$BASE" "$OURS" "$THEIRS" -o "$OURS" 2>/dev/null; then
        exit 0
    fi
    # Neither semantic nor line-based merge succeeded.
    # Exit non-zero so Git falls back to its default conflict behavior.
    echo "suture: merge conflict on ${4:-$OURS}" >&2
    exit 1
fi
