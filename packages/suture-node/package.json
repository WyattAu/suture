{
  "name": "suture-merge-driver",
  "version": "5.1.0",
  "description": "Semantic merge for JSON, YAML, TOML, XML, CSV and 12+ more structured file formats. Works as a Git merge driver.",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "bin": {
    "suture-merge-driver": "src/cli.js"
  },
  "files": [
    "src/",
    "README.md"
  ],
  "scripts": {
    "build": "cargo-cp --release --strip",
    "install": "node-gyp-build",
    "test": "echo 'No tests yet'"
  },
  "napi": {
    "name": "suture",
    "triples": {}
  },
  "devDependencies": {
    "@napi-rs/cli": "^2",
    "cargo-cp": "^0.1",
    "node-gyp-build": "^4"
  },
  "keywords": [
    "semantic-merge",
    "json-merge",
    "yaml-merge",
    "toml-merge",
    "git-merge-driver",
    "merge-conflict",
    "config-merge",
    "structured-data",
    "ci-cd",
    "automation"
  ],
  "author": "WyattAu",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/WyattAu/suture.git",
    "directory": "packages/suture-node"
  },
  "homepage": "https://suture.dev",
  "bugs": {
    "url": "https://github.com/WyattAu/suture/issues"
  }
}
