{
  "name": "vscode-suture",
  "displayName": "Suture Semantic Merge",
  "description": "Semantic merge for structured files — JSON, YAML, TOML, XML, and more",
  "version": "0.1.0",
  "publisher": "wyattau",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "suture.semanticMerge",
        "title": "Suture: Semantic Merge Current File"
      },
      {
        "command": "suture.init",
        "title": "Suture: Initialize Repository"
      },
      {
        "command": "suture.status",
        "title": "Suture: Show Status"
      }
    ],
    "configuration": {
      "title": "Suture",
      "properties": {
        "suture.path": {
          "type": "string",
          "default": "suture",
          "description": "Path to the suture CLI binary"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
